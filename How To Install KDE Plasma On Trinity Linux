1 Go To TTY3
2 Remove GNOME And GDM sudo dnf remove gnome-session sudo systemctl stop gdm sudo systemctl disable gdm sudo dnf remove gdm -y
3 Install KDE Plasma sudo dnf install @kde-desktop -y
4 sudo systemctl set-default graphical.target (if not already set)
5 sudo systemctl enable sddm --force
  sudo systemctl start sddm
6 Login To KDE Plasma
7 Open System Settings Then Colors And Themes Then Global Theme Then Select Breeze Then Check Desktop and window layout then click apply
8 Go To Login Screen (SDDM) Then Change Breeze Fedora To Breeze
9 For GNOME Switch KDE Plasma Users Remove GNOME Apps 
  sudo dnf remove nautilus gedit gnome-system-monitor gnome-control-center gnome-tweaks gnome-calculator gnome-calendar gnome-disk-utility gnome-screenshot gnome-chess gnome-terminal gnome-weather gnome-maps gnome-clocks gnome-contacts gnome-photos -y; sudo dnf remove gnome-backgrounds gnome-software gnome-extensions-app eog -y; sudo dnf install gnome-calendar -y; sudo dnf install gnome-chess -y; sudo dnf remove gnome-sudoku -y; sudo dnf remove gnome-tetravex -y; sudo dnf remove gnome-mines -y; sudo dnf remove gnome-robots -y; sudo dnf remove gnome-nibbles -y
